# --- Core ---------------------------------------------------------------
# "development" (default) or "production". Production turns on secure cookies
# + https and requires the few vars below. On Render this is auto-detected.
APP_ENV=development

# Optional. If unset, a persistent key is generated and stored in the database
# on first boot, so you don't have to manage one. To pin your own:
# python -c "import secrets; print(secrets.token_hex(32))"
# SECRET_KEY=

# --- Database -------------------------------------------------------------
# Leave unset locally to use SQLite (firstlight-dev.db in the project root).
# On Render this is injected from the managed Postgres database. REQUIRED in
# production (the app refuses to start on ephemeral SQLite there).
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# --- Email (REQUIRED in production) ----------------------------------------
# Option A (recommended on Render): Brevo HTTP API. Render's free tier blocks
# outbound SMTP ports entirely, so classic SMTP (incl. Gmail) will time out
# there. Create a free Brevo account -> Settings -> SMTP & API -> API Keys.
BREVO_API_KEY=

# Option B: any SMTP relay (Gmail app password, Resend, Postmark, Mailgun...).
# Only used when BREVO_API_KEY is empty. Port 465 uses SSL, others STARTTLS.
# Leave everything empty in dev: emails print to the console instead.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# The "From" address. Must be a sender you've verified with your email
# provider (Brevo/Gmail/etc). Contact-form messages are sent to whichever
# email owns the admin account (claimed at /setup) — no separate var needed.
MAIL_FROM="First Light <hello@example.com>"

# --- Lemon Squeezy (optional; set when you wire up payments) ----------------
# Webhook secret: LS dashboard -> Settings -> Webhooks -> signing secret.
#   (Until set, incoming webhooks are rejected; the rest of the site works.)
# API key:        LS dashboard -> Settings -> API -> "+" (for the Sync button).
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_API_KEY=
